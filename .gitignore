# OS
.DS_Store

# AI tool local config (each user generates their own)
.claude/
!.claude/commands/
.cursor/

# Runtime task workspaces (designer-specific, not shared)
tasks/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Onboarding knowledge base (team-specific, generated per-team)
# Uncomment the line below if each team should generate their own:
# .harnessdesign/knowledge/product-context/*.md
# Keep .gitkeep files
!.harnessdesign/knowledge/product-context/.gitkeep

# Session archives (conversation-specific)
.harnessdesign/memory/sessions/*.md
!.harnessdesign/memory/sessions/.gitkeep

# Constraint memories (conversation-specific)
.harnessdesign/memory/constraints/*.md
!.harnessdesign/memory/constraints/.gitkeep
